#!/usr/bin/env bash
#
# Pre-commit hook: traceability enforcement (the Wall)
#
# Rule: if this commit touches files under src/, then ONE of:
#   (a) a file under specs/ is also staged in this commit, OR
#   (b) a file under fixes/ is also staged in this commit, OR
#   (c) a file under investigations/ is also staged in this commit, OR
#   (d) the commit message references a spec, fix, or investigation
#       by path or §ref, OR
#   (e) a §ref:specs/..., §ref:fixes/..., or §ref:investigations/...
#       comment is added in this commit's code.
#
# Install:
#   cp pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Bypass (sparingly, leaves audit trail in git log):
#   git commit --no-verify
#
# Tune the SRC_PATTERN below if your repo layout differs.

set -euo pipefail

SRC_PATTERN='^(src|lib|app)/'
SPEC_PATTERN='^specs/'
FIX_PATTERN='^fixes/'
INVESTIGATION_PATTERN='^investigations/'
COMMIT_MSG_FILE="${1:-}"  # populated when called as commit-msg hook

# Best-effort ledger logging. Silent on failure — never blocks the hook.
_log_gate() {
    local outcome="$1" reason="${2:-}"
    local repo_root ledger
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -z "$repo_root" ]] && return 0
    ledger="$repo_root/.attest/ledger/attest_ledger.py"
    [[ -f "$ledger" ]] || return 0
    if [[ "$outcome" == "blocked" ]]; then
        python3 "$ledger" log gate_blocked source='"pre-commit"' \
            reason="\"$reason\"" --quiet 2>/dev/null || true
    elif [[ "$outcome" == "passed" ]]; then
        python3 "$ledger" log gate_passed source='"pre-commit"' \
            --quiet 2>/dev/null || true
    fi
}

# Coverage gate. Returns 0 if coverage policy is satisfied (or no policy
# declared, or no ledger installed). Returns 1 if the most recent coverage
# measurement failed.
#
# This is a soft check: it reads from the ledger rather than re-running the
# coverage tool. The assumption is that /work or /fix already measured
# coverage in its post-flight. If no recent measurement exists, we don't
# block — the absence of measurement is a /work problem, not a commit-time
# problem (and forcing a coverage run inside a git hook would make commits
# painfully slow).
_check_coverage_gate() {
    local repo_root ledger claude_md
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -z "$repo_root" ]] && return 0
    claude_md="$repo_root/CLAUDE.md"
    ledger="$repo_root/.attest/ledger/attest_ledger.py"

    # No CLAUDE.md or no Coverage policy section → skip
    [[ -f "$claude_md" ]] || return 0
    grep -q "^##\s\+Coverage policy" "$claude_md" 2>/dev/null || return 0

    # No ledger installed → skip
    [[ -f "$ledger" ]] || return 0

    # Only check if src/lib/app changes are staged
    local has_src
    has_src=$(echo "$staged_files" | grep -E "$SRC_PATTERN" | head -1)
    [[ -z "$has_src" ]] && return 0

    # Rebuild the index so we read the latest events. The JSONL is the
    # source of truth; the SQLite index may be stale if /work logged a
    # coverage event but no one ran rebuild-index since. Rebuild is fast
    # (under 200ms for typical repos).
    python3 "$ledger" rebuild-index >/dev/null 2>&1 || true

    # Look at the most recent coverage_measured event. If it's a fail,
    # block. If it's a pass, allow. If none exists, allow (with a warning).
    local result
    result=$(python3 "$ledger" query \
        "SELECT passed FROM coverage ORDER BY ts DESC LIMIT 1" \
        2>/dev/null | tail -1 | tr -d ' ')

    if [[ -z "$result" || "$result" == "(no" ]]; then
        # No coverage measurements at all — warn but allow
        echo "Pre-commit: CLAUDE.md declares a Coverage policy but no" >&2
        echo "  coverage_measured events found in the ledger." >&2
        echo "  Run /work or /fix to measure coverage, or check that your" >&2
        echo "  coverage tool runs in CI." >&2
        return 0
    fi

    if [[ "$result" == "0" ]]; then
        cat >&2 <<EOF

The most recent coverage measurement in the ledger failed:

EOF
        python3 "$ledger" query \
            "SELECT ts, artifact, delta_pct, threshold_delta, tool
             FROM coverage WHERE passed = 0
             ORDER BY ts DESC LIMIT 1" >&2 2>/dev/null || true
        cat >&2 <<EOF

Options:
  - Re-run /work or /fix to add tests until coverage passes
  - Bypass deliberately with --no-verify (logged separately)

EOF
        _log_gate blocked "coverage-below-threshold"
        return 1
    fi

    return 0
}

# Get the list of staged files (added, copied, modified, renamed)
staged_files=$(git diff --cached --name-only --diff-filter=ACMR || true)

if [[ -z "$staged_files" ]]; then
    exit 0
fi

# Check whether any src/ files are being committed
src_changed=$(echo "$staged_files" | grep -E "$SRC_PATTERN" || true)

if [[ -z "$src_changed" ]]; then
    # No production code changing; nothing to enforce.
    exit 0
fi

# A src/ change is happening. Check for spec, fix, or investigation linkage.
spec_staged=$(echo "$staged_files" | grep -E "$SPEC_PATTERN" || true)
fix_staged=$(echo "$staged_files" | grep -E "$FIX_PATTERN" || true)
investigation_staged=$(echo "$staged_files" | grep -E "$INVESTIGATION_PATTERN" || true)

if [[ -n "$spec_staged" || -n "$fix_staged" || -n "$investigation_staged" ]]; then
    _check_coverage_gate || exit 1
    _log_gate passed
    exit 0
fi

# Look at the commit message for a spec, fix, or investigation reference.
ref_in_msg=""
if [[ -n "$COMMIT_MSG_FILE" && -f "$COMMIT_MSG_FILE" ]]; then
    if grep -qE '(specs|fixes|investigations)/[a-zA-Z0-9._/-]+\.md|§ref:(specs|fixes|investigations)/' "$COMMIT_MSG_FILE"; then
        ref_in_msg="yes"
    fi
fi

if [[ -n "$ref_in_msg" ]]; then
    _check_coverage_gate || exit 1
    _log_gate passed
    exit 0
fi

# Last resort: check if any staged src/ file's diff contains a §ref:specs/,
# §ref:fixes/, or §ref:investigations/ comment.
if echo "$staged_files" | grep -E "$SRC_PATTERN" | while read -r f; do
    if git diff --cached "$f" | grep -qE '\+.*§ref:(specs|fixes|investigations)/'; then
        echo "found"
        break
    fi
done | grep -q "found"; then
    _check_coverage_gate || exit 1
    _log_gate passed
    exit 0
fi

# No linkage anywhere. Block.
cat <<EOF >&2

╔══════════════════════════════════════════════════════════════════╗
║  COMMIT BLOCKED — no spec, fix, or investigation linkage found    ║
╚══════════════════════════════════════════════════════════════════╝

This commit touches production code (matching $SRC_PATTERN) but does
not link to a spec, fix, or investigation. The Wall requires that
production changes carry traceability.

To satisfy this hook, do one of:

  1. Stage a spec, fix, or investigation in this commit:
       git add specs/YYYY-MM-DD-your-slug.md
       (or)
       git add fixes/YYYY-MM-DD-your-slug-against-X.md
       (or)
       git add investigations/YYYY-MM-DD-your-slug.md

  2. Reference one in the commit message:
       git commit -m "fix: handle null preferences

       §ref:fixes/2026-05-12-null-prefs-against-notif-prefs.md"

  3. Add a §ref:specs/, §ref:fixes/, or §ref:investigations/ comment
     in the code.

For genuine non-traceable changes (formatting, dependency bumps,
emergency hotfix), bypass deliberately:

       git commit --no-verify

Bypasses are visible in the audit trail. Use them honestly.

EOF
_log_gate blocked "no-linkage"
exit 1
